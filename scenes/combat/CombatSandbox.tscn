[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/combat/combat_sandbox.gd" id="1_script"]

[node name="CombatSandbox" type="Node2D"]
script = ExtResource("1_script")

[node name="CanvasLayer" type="CanvasLayer" parent="."]

[node name="HUDPanel" type="PanelContainer" parent="CanvasLayer"]
offset_left = 12.0
offset_top = 12.0
offset_right = 900.0
offset_bottom = 368.0

[node name="VBox" type="VBoxContainer" parent="CanvasLayer/HUDPanel"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="TitleLabel" type="Label" parent="CanvasLayer/HUDPanel/VBox"]
layout_mode = 2
text = "Combat Sandbox（Phase 1）：WASD移动，鼠标左键射击"

[node name="HelpLabel" type="Label" parent="CanvasLayer/HUDPanel/VBox"]
layout_mode = 2
text = "目标：验证战斗门槛（ATK/DEF/Corruption/Fate）在实时战斗中可感知。"

[node name="StatsLabel" type="Label" parent="CanvasLayer/HUDPanel/VBox"]
layout_mode = 2
text = "玩家/敌人数值"

[node name="ThresholdLabel" type="Label" parent="CanvasLayer/HUDPanel/VBox"]
layout_mode = 2
text = "阈值信息"

[node name="ResultLabel" type="Label" parent="CanvasLayer/HUDPanel/VBox"]
layout_mode = 2
text = "战斗进行中..."

[node name="LogTitle" type="Label" parent="CanvasLayer/HUDPanel/VBox"]
layout_mode = 2
text = "战斗日志（可解释）"

[node name="LogOutput" type="RichTextLabel" parent="CanvasLayer/HUDPanel/VBox"]
custom_minimum_size = Vector2(0, 180)
layout_mode = 2
size_flags_vertical = 3
scroll_active = true
selection_enabled = true

[node name="ButtonRow" type="HBoxContainer" parent="CanvasLayer/HUDPanel/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="ResetButton" type="Button" parent="CanvasLayer/HUDPanel/VBox/ButtonRow"]
layout_mode = 2
text = "重置战斗"

[node name="BackButton" type="Button" parent="CanvasLayer/HUDPanel/VBox/ButtonRow"]
layout_mode = 2
text = "返回主流程"

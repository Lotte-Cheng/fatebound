[node name="BlessOptionB" type="Button" parent="CanvasLayer/HudPanel/VBox/PrayerPanel"]
layout_mode = 2
text = "祝福 B"

[node name="BlessOptionC" type="Button" parent="CanvasLayer/HudPanel/VBox/PrayerPanel"]
layout_mode = 2
text = "祝福 C"

[node name="DeityResponseTitle" type="Label" parent="CanvasLayer/HudPanel/VBox/PrayerPanel"]
